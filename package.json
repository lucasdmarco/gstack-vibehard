{
  "name": "@gstack-vibehard/installer",
  "version": "3.7.2",
  "description": "gstack_vibehard — Cross-harness installer & fullstack template kit with deep agent integration (Codex, Claude Code, OpenCode)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "gstack_vibehard": "src/index.js"
  },
  "scripts": {
    "gstack_vibehard": "node src/index.js",
    "build:agents": "node scripts/scripts/build_agents.js",
    "setup": "node src/index.js install",
    "doctor": "node src/index.js doctor",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:e2e": "node --test \"tests/e2e/**/*.e2e.test.js\"",
    "test:pack": "node scripts/test-pack.mjs",
    "test:templates": "node scripts/test-templates.mjs",
    "test:accept": "sh scripts/clean-install-acceptance.sh",
    "test:py": "python -m pytest tests/ -q || python -m unittest discover -s tests -p \"test_*.py\"",
    "lint": "node scripts/lint.mjs",
    "syntaxcheck": "node scripts/lint.mjs --typecheck",
    "typecheck": "node scripts/lint.mjs --typecheck",
    "clean": "node scripts/clean-pkg.mjs",
    "prepack": "node scripts/clean-pkg.mjs",
    "sync:qg": "node scripts/sync-qg-version.mjs",
    "version": "node scripts/sync-qg-version.mjs && git add hooks/hooks/qg.py"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "hooks/",
    "skills/",
    "agents/",
    "templates/",
    "scripts/",
    "mcp-configs/",
    "core/",
    "knowledge/",
    "launchers/cross/install.sh",
    "launchers/macos/gstack_vibehard.rb",
    "launchers/windows/install.bat",
    "launchers/windows/gstack_vibehard.cmd",
    "src/plugins/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "peerDependencies": {
    "@agentmemory/agentmemory": "0.x",
    "fallow": "0.x"
  },
  "peerDependenciesMeta": {
    "fallow": {
      "optional": true
    },
    "@agentmemory/agentmemory": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasdmarco/gstack-vibehard.git"
  },
  "keywords": [
    "gstack_vibehard",
    "claude-code",
    "codex-cli",
    "opencode",
    "agent-skills",
    "fullstack-template",
    "taste-skill",
    "quality-gate"
  ],
  "dependencies": {
    "smol-toml": "^1.6.1"
  }
}
