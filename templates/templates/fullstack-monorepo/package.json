{
  "name": "my-project",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev:api-fastify": "cd apps/api-fastify && npm run dev",
    "dev:api-hono": "cd apps/api-hono && npm run dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "cd apps/api && npm run test",
    "test:watch": "cd apps/api && npm run test:watch",
    "db:generate": "cd packages/db && npx drizzle-kit generate",
    "db:push": "cd packages/db && npx drizzle-kit push",
    "db:push:test": "cd packages/db && cross-env DB_ENV=test npx drizzle-kit push",
    "db:studio": "cd packages/db && npx drizzle-kit studio",
    "db:seed": "tsx packages/db/src/seed.ts",
    "db:types": "npx supabase gen types typescript --linked > packages/db/src/supabase.ts",
    "db-turso:generate": "cd packages/db-turso && npx drizzle-kit generate",
    "db-turso:push": "cd packages/db-turso && npx drizzle-kit push",
    "db-turso:seed": "tsx packages/db-turso/src/seed.ts",
    "coverage:gaps": "fallow coverage setup --yes --json",
    "setup:repo": "powershell -File scripts/setup-repo.ps1",
    "format": "prettier --write .",
    "postinstall": "node scripts/postinstall-fallow.mjs"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0"
  }
}
