{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd apps/api-fastify && npm run build"
  },
  "deploy": {
    "startCommand": "cd apps/api-fastify && node dist/index.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "on-failure"
  }
}
